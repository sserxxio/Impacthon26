// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id                 Int      @id @default(autoincrement())
  guestId            String   @unique
  country            String
  gender             String?
  ageRange           String?
  last2Years         Int      @default(0)
  confirmedBookings  Int      @default(0)
  numDistinctions    Int      @default(0)
  confirmedCancels   Float    @default(0)
  avgLength          Float    @default(0)
  avgBookingValue    Float    @default(0)
  avgScore           Float    @default(0)
  reservationId      Int?
  checkinDate        String?
  checkoutDate       String?
  hotelId            Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Hotel {
  id               Int      @id @default(autoincrement())
  hotelDbId        Int      @unique
  hotelName        String
  country          String
  brand            String?
  stars            Int      @default(0)
  numRooms         Int      @default(0)
  cityName         String?
  cityClimate      String?
  cityAvgTemp      Float    @default(0)
  cityRain         String?
  cityBeach        String?
  cityMountain     String?
  cityHistoric     String?
  cityPrice        String?
  cityGastro       String?
  amenities        HotelAmenities?
  analyses         Analysis[]
  statistics       Statistics[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HotelAmenities {
  id               Int      @id @default(autoincrement())
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId          Int      @unique
  
  // Instalaciones deportivas
  piscina          Boolean  @default(false)
  pistasTenis      Boolean  @default(false)
  padel            Boolean  @default(false)
  gimnasio         Boolean  @default(false)
  
  // Servicios principales
  restaurante      Boolean  @default(false)
  bar              Boolean  @default(false)
  spa              Boolean  @default(false)
  sauna            Boolean  @default(false)
  buffet           Boolean  @default(false)
  
  // Conectividad
  wifiGratis       Boolean  @default(false)
  
  // Estacionamiento
  estacionamientoGratis Boolean @default(false)
  
  // Habitaciones y servicios especiales
  habitacionesVIP  Boolean  @default(false)
  permiteMascotas  Boolean  @default(false)
  salaJuegos       Boolean  @default(false)
  guarderia        Boolean  @default(false)
  sitioFumar       Boolean  @default(false)
  
  // Accesibilidad e idiomas
  accesibilidad    Boolean  @default(false)
  idiomas          Boolean  @default(false)
  
  // Actividades y facilidades
  actividades      Boolean  @default(false)
  earlyCheckin     Boolean  @default(false)
  lateCheckin      Boolean  @default(false)
  
  // Notas adicionales
  notasAdicionales String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Analysis {
  id               Int      @id @default(autoincrement())
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId          Int
  
  // Resultado del análisis
  estrategia       String
  anuncio          String
  segmentoObjeto   String?
  diferencadores   String?

  
  
  // Recomendaciones de mejora
  recomendaciones  String? // JSON array
  
  // Metadata
  modeloUsado      String   @default("gemini-2.0-flash")
  errorCount       Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Statistics {
  id               Int      @id @default(autoincrement())
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId          Int
  
  // Período
  month            Int      // 1-12
  year             Int
  
  // Datos financieros
  ingresos         Float    @default(0)
  costes           Float    @default(0)
  marketingGasto   Float    @default(0)
  utilidad         Float    @default(0)
  roi              Float    @default(0)
  
  // Datos operacionales
  ocupacion        Float    @default(0)     // porcentaje
  adr              Float    @default(0)     // Average Daily Rate
  reservas         Int      @default(0)
  huespedes        Int      @default(0)
  
  // Reputación
  puntuacion       Float    @default(0)
  resenas          Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([hotelId, month, year])
}
